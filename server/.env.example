# Copy this file to .env (optional — the app runs with no config).

# MongoDB connection string. LEAVE BLANK to use a zero-setup in-memory MongoDB
# (great for testing; data resets when the server stops). Set it to a real
# MongoDB (local mongod or Atlas) to persist data.
MONGODB_URI=

# Port the server listens on (also serves the built client in production).
PORT=4000

# OPTIONAL server-side Anthropic key fallback. If blank, the AI chat uses the
# key entered via the in-app AI Settings gear (original behavior).
ANTHROPIC_API_KEY=
